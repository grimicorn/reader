// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`SearchOverlay > matches snapshot (closed) 1`] = `"<!--v-if-->"`;

exports[`SearchOverlay > matches snapshot (open, empty query) 1`] = `
"<div class="search-scrim">
  <div class="search-modal">
    <div class="search-in">
      <ricon name="search" size="22"></ricon><input id="reader-search-input" placeholder="search posts, podcasts, videos, pages…"><span class="kbd">esc</span><button class="icon-btn">
        <ricon name="x" size="18"></ricon>
      </button>
    </div>
    <div class="search-results">
      <div class="sr-group">Pages</div>
      <div class="sr-item cursor"><span class="sr-pill" style="--c: var(--accent-soft-ink);">PAGE</span>
        <div class="sr-main">
          <div class="sr-title">Dashboard</div>
          <div class="sr-sub">Your unified feed</div>
        </div><span class="sr-arrow"><ricon name="arrowRight" size="16"></ricon></span>
      </div>
      <div class="sr-item"><span class="sr-pill" style="--c: var(--accent-soft-ink);">PAGE</span>
        <div class="sr-main">
          <div class="sr-title">Settings</div>
          <div class="sr-sub">Feeds &amp; connected accounts</div>
        </div><span class="sr-arrow"><ricon name="arrowRight" size="16"></ricon></span>
      </div>
      <div class="sr-item"><span class="sr-pill" style="--c: var(--accent-soft-ink);">PAGE</span>
        <div class="sr-main">
          <div class="sr-title">Sign in</div>
          <div class="sr-sub">Account &amp; session</div>
        </div><span class="sr-arrow"><ricon name="arrowRight" size="16"></ricon></span>
      </div>
      <div class="sr-group">Recent</div>
      <div class="sr-item"><span class="sr-pill" style="--c: var(--src-rss);">RSS</span>
        <div class="sr-main">
          <div class="sr-title">The Quiet Death of the Homepage</div>
          <div class="sr-sub">A Working Library · 6 min read</div>
        </div><span class="sr-arrow"><ricon name="arrowRight" size="16"></ricon></span>
      </div>
      <div class="sr-item"><span class="sr-pill" style="--c: var(--src-video);">YouTube</span>
        <div class="sr-main">
          <div class="sr-title">I rebuilt my entire homelab from scratch (and it was worth it)</div>
          <div class="sr-sub">Wolfgang's Channel · 18:42</div>
        </div><span class="sr-arrow"><ricon name="arrowRight" size="16"></ricon></span>
      </div>
      <div class="sr-item"><span class="sr-pill" style="--c: var(--src-tweet);">X</span>
        <div class="sr-main">
          <div class="sr-title">the best abstraction is the one you can delete in an afternoon. everything else is a liability wearing a nice hat.</div>
          <div class="sr-sub">Dan Abramov · 342 · 28</div>
        </div><span class="sr-arrow"><ricon name="arrowRight" size="16"></ricon></span>
      </div>
      <div class="sr-item"><span class="sr-pill" style="--c: var(--src-podcast);">Podcast</span>
        <div class="sr-main">
          <div class="sr-title">Web Components in 2026 — Are We There Yet?</div>
          <div class="sr-sub">Syntax · 1:04:12</div>
        </div><span class="sr-arrow"><ricon name="arrowRight" size="16"></ricon></span>
      </div>
      <div class="sr-item"><span class="sr-pill" style="--c: var(--src-photo);">Instagram</span>
        <div class="sr-main">
          <div class="sr-title">morning fog rolling over the valley — worth the 5am alarm ☁️</div>
          <div class="sr-sub">grimicornsparkles · 1,204 likes</div>
        </div><span class="sr-arrow"><ricon name="arrowRight" size="16"></ricon></span>
      </div>
      <div class="sr-item"><span class="sr-pill" style="--c: var(--src-rss);">RSS</span>
        <div class="sr-main">
          <div class="sr-title">Why I switched back to RSS after ten years away</div>
          <div class="sr-sub">The Verge · 4 min read</div>
        </div><span class="sr-arrow"><ricon name="arrowRight" size="16"></ricon></span>
      </div>
      <!--v-if-->
    </div>
    <div class="search-foot"><span class="hint"><span class="kbd">↑↓</span> navigate</span><span class="hint"><span class="kbd">↵</span> open</span><span class="hint"><span class="kbd">esc</span> close</span></div>
  </div>
</div>"
`;
