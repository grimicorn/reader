// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`AppHeader > matches snapshot 1`] = `
"<header class="appbar">
  <div class="wrap appbar-in"><a href="/" class="brand">
      <rlogo size="28" words=""></rlogo>
    </a>
    <nav class="nav"><a href="/" class="active">dashboard<span class="num">01</span></a><a href="/settings" class="">settings<span class="num">02</span></a></nav>
    <div class="appbar-right"><button class="search-trigger">
        <ricon name="search" size="16"></ricon><span class="st-label">Search everything…</span><span class="kbd">⌘K</span>
      </button><button class="icon-btn" title="Refresh feeds">
        <ricon name="refresh" size="18"></ricon>
      </button><button class="icon-btn has-dot" title="Notifications">
        <ricon name="bell" size="18"></ricon>
      </button><button class="icon-btn" title="Theme: system">
        <ricon name="monitor" size="18"></ricon>
      </button><a href="/settings" class="avatar-btn" title="Account">JR</a></div>
  </div>
</header>"
`;
