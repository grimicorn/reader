// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`PhotoCard > matches snapshot 1`] = `
"<article class="card card-photo">
  <div class="ph ratio-photo" data-label="https://example.com/photo.jpg"><span class="photo-badge src-photo"><ricon name="photo" size="12"></ricon> Instagram</span></div>
  <div class="photo-cap">
    <div class="card-head tight">
      <sourcetag item="[object Object]"></sourcetag>
      <cardactions item="[object Object]"></cardactions>
    </div>
    <p class="photo-text">A beautiful test photo caption.</p><span class="card-meta">234 likes</span>
  </div>
</article>"
`;
