// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`AppToast > matches snapshot (hidden) 1`] = `"<div name="toast"></div>"`;

exports[`AppToast > matches snapshot (visible) 1`] = `
"<div name="toast">
  <div class="toast">
    <ricon name="check" size="15"></ricon> Feed added
  </div>
</div>"
`;
